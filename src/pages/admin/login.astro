---
import Layout from '../../layouts/Layout.astro';

const error = Astro.url.searchParams.get('error');
const redirect = Astro.url.searchParams.get('redirect') ?? '/admin';
---

<Layout title="Вход — Панель администратора">
  <main class="min-h-screen flex items-center justify-center px-4">
    <div class="bg-white rounded-2xl shadow-sm p-8 w-full max-w-sm">
      <h1 class="text-2xl font-bold text-gray-900 mb-2">Вход</h1>
      <p class="text-sm text-gray-500 mb-6">Панель администратора</p>

      {error && (
        <div class="mb-4 text-sm text-red-600 bg-red-50 rounded-lg px-3 py-2">
          Неверный пароль. Попробуйте ещё раз.
        </div>
      )}

      <form method="POST" action="/api/auth/login" class="space-y-4">
        <input type="hidden" name="redirect" value={redirect} />

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="password">
            Пароль
          </label>
          <input
            type="password"
            id="password"
            name="password"
            required
            autofocus
            placeholder="Введите пароль"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg px-4 py-2 min-h-10 text-sm transition-colors"
        >
          Войти
        </button>
      </form>
    </div>
  </main>
</Layout>
